# Copy to .env.test.local and add your GitHub classic PAT (ghp_...) with repo + delete_repo scope.
NOOK_GITHUB_PAT=
# Optional: pin one repo for the whole run (CI sets nook-e2e-$RUN_ID; local can reuse too)
# NOOK_GITHUB_E2E_REPO=nook-my-debug
# Optional: faster vault sync / GitHub polling during e2e (playwright.config.ts sets defaults)
# VITE_VAULT_SYNC_INTERVAL_MS=1000
# NOOK_GITHUB_POLL_MS=2500
# NOOK_GITHUB_SYNC_TIMEOUT_MS=15000
# NOOK_GITHUB_CONNECT_TIMEOUT_MS=30000
