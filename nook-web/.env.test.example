# Copy to .env.test.local and add your GitHub classic PAT (ghp_...) with repo + delete_repo scope.
NOOK_GITHUB_PAT=
# Optional: pin a fixed repo for local debugging (auto-generated repos are deleted after e2e)
# NOOK_GITHUB_E2E_REPO=nook-my-debug
# Optional: faster vault sync / GitHub polling during e2e (playwright.config.ts sets defaults)
# VITE_VAULT_SYNC_INTERVAL_MS=500
# NOOK_GITHUB_POLL_MS=250
