{
  "name": "nook-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.config.json",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:local": "playwright test e2e/connect.spec.ts e2e/local-vault.spec.ts e2e/login-unlock-flow.spec.ts e2e/onboard-providers.spec.ts e2e/password-envelope-local.spec.ts",
    "test:e2e:github": "playwright test e2e/github-vault.spec.ts",
    "test:e2e:multi-device": "playwright test e2e/multi-device-github.spec.ts",
    "test:e2e:cleanup": "bun e2e/cleanup-github-repos.ts",
    "test:all": "vitest run && playwright test"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.55.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.1",
    "@tsconfig/svelte": "5.0.8",
    "@types/bun": "1.3.14",
    "@types/dompurify": "3.0.5",
    "@types/markdown-it": "14.1.2",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/parser": "8.61.1",
    "dotenv": "^16.6.1",
    "eslint": "10.5.0",
    "eslint-plugin-svelte": "3.19.0",
    "globals": "17.6.0",
    "happy-dom": "20.10.6",
    "prettier": "3.8.4",
    "prettier-plugin-svelte": "4.1.1",
    "svelte": "5.56.3",
    "svelte-check": "4.6.0",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@lucide/svelte": "1.21.0",
    "clsx": "2.1.1",
    "dompurify": "3.4.11",
    "github-markdown-css": "5.8.1",
    "markdown-it": "14.2.0",
    "qrcode": "^1.5.4",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2",
    "tw-animate-css": "1.4.0"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-darwin-arm64": "^4.3.1"
  }
}
