{
  "name": "nook-web-research",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "bun run unused && svelte-check --tsconfig ./tsconfig.json && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "unused": "knip --reporter compact"
  },
  "dependencies": {
    "@lucide/svelte": "1.21.0",
    "clsx": "2.1.1",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.1",
    "@tsconfig/svelte": "5.0.8",
    "knip": "5.88.0",
    "prettier": "3.8.4",
    "prettier-plugin-svelte": "4.1.1",
    "svelte": "5.56.3",
    "svelte-check": "4.6.0",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
