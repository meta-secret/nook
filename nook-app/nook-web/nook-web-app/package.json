{
  "name": "nook-web-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "postinstall": "cd .. && test -e node_modules || ln -s nook-web-app/node_modules node_modules",
    "dev": "vite",
    "build": "bun run build:unified && bun run build:site && bun run build:simple && bun run build:sentinel && bun run assemble:preview && bun run verify:isolation",
    "build:unified": "vite build --mode unified",
    "build:site": "vite build --mode site",
    "build:simple": "cd ../nook-vault-simple && bun run build",
    "build:sentinel": "cd ../nook-vault-sentinel && bun run build",
    "assemble:preview": "bun scripts/assemble-preview.ts",
    "verify:isolation": "bun scripts/verify-app-isolation.ts",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.config.json && cd ../nook-vault-simple && bun run check && cd ../nook-vault-sentinel && bun run check",
    "lint": "cd .. && node_modules/.bin/eslint --config eslint.config.js nook-web-app nook-web-shared/src/vault-app nook-vault-simple nook-vault-sentinel && node_modules/.bin/prettier --check nook-web-app nook-web-shared/src/vault-app nook-vault-simple nook-vault-sentinel",
    "format": "prettier --write . ../nook-web-shared/src/vault-app ../nook-vault-simple ../nook-vault-sentinel",
    "format:check": "prettier --check . ../nook-web-shared/src/vault-app ../nook-vault-simple ../nook-vault-sentinel",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "bun run test:e2e:stable && bun run test:e2e:unstable",
    "test:e2e:stable": "PLAYWRIGHT_WORKERS=6 playwright test --project=stable",
    "test:e2e:unstable": "PLAYWRIGHT_WORKERS=4 playwright test --project=unstable",
    "test:e2e:pr": "bun run test:e2e:stable",
    "test:e2e:isolation": "playwright test --config playwright.isolation.config.ts",
    "test:e2e:local": "bun run test:e2e:stable",
    "test:e2e:sync-stub": "bun run test:e2e",
    "test:e2e:sync-live": "playwright test --project=sync-live",
    "test:e2e:github": "playwright test --project=sync-live",
    "test:e2e:multi-device": "PLAYWRIGHT_WORKERS=4 playwright test --project=unstable e2e/multi-device-sync.spec.ts",
    "test:e2e:cleanup": "bun e2e/cleanup-github-repos.ts",
    "test:all": "vitest run && playwright test"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@internationalized/date": "^3.12.0",
    "@playwright/test": "^1.55.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/svelte": "^5.4.2",
    "@tsconfig/svelte": "5.0.8",
    "@types/bun": "1.3.14",
    "@types/dompurify": "3.0.5",
    "@types/markdown-it": "14.1.2",
    "@types/node": "24.13.2",
    "@typescript-eslint/parser": "8.61.1",
    "bits-ui": "^2.16.3",
    "dotenv": "^16.6.1",
    "eslint": "10.5.0",
    "eslint-plugin-svelte": "3.19.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "17.6.0",
    "happy-dom": "20.10.6",
    "prettier": "3.8.4",
    "prettier-plugin-svelte": "4.1.1",
    "svelte": "5.56.3",
    "svelte-check": "4.6.0",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@lucide/svelte": "1.21.0",
    "clsx": "2.1.1",
    "dompurify": "3.4.11",
    "github-markdown-css": "5.8.1",
    "markdown-it": "14.2.0",
    "mermaid": "^11.16.0",
    "qr-code-styling": "1.9.2",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2",
    "tw-animate-css": "1.4.0"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "1.0.3",
    "@rolldown/binding-linux-x64-gnu": "1.0.3",
    "@tailwindcss/oxide-darwin-arm64": "4.3.1",
    "@tailwindcss/oxide-linux-x64-gnu": "4.3.1",
    "lightningcss-darwin-arm64": "1.32.0",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
