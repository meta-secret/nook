{
  "name": "nook-vault-sentinel",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "prepare:toolchain": "test -e ../node_modules || ln -s nook-web-app/node_modules ../node_modules; test -e node_modules || ln -s ../nook-web-app/node_modules node_modules",
    "dev": "bun run prepare:toolchain && vite",
    "build": "bun run prepare:toolchain && vite build",
    "preview": "bun run prepare:toolchain && vite preview",
    "check": "bun run prepare:toolchain && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@lucide/svelte": "1.21.0",
    "@internationalized/date": "^3.12.0",
    "bits-ui": "^2.16.3",
    "clsx": "2.1.1",
    "dompurify": "3.4.11",
    "github-markdown-css": "5.8.1",
    "markdown-it": "14.2.0",
    "mermaid": "^11.16.0",
    "qr-code-styling": "1.9.2",
    "svelte": "5.56.3",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.1",
    "@tsconfig/svelte": "5.0.8",
    "@types/node": "24.13.2",
    "svelte-check": "4.6.0",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
