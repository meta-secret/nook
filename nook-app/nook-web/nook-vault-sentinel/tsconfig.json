{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "types": ["svelte", "vite/client", "node"],
    "noEmit": true,
    "allowJs": true,
    "moduleDetection": "force",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "paths": {
      "$lib/extension-connect": ["./src/extension-connect-disabled.ts"],
      "$lib/components/ExtensionConnectConsent.svelte": [
        "./src/ExtensionConnectDisabled.svelte"
      ],
      "$lib": ["../nook-web-shared/src/vault-app/lib"],
      "$lib/*": ["../nook-web-shared/src/vault-app/lib/*"],
      "$vault-shared": ["../nook-web-shared/src/vault-app"],
      "$vault-shared/*": ["../nook-web-shared/src/vault-app/*"],
      "$web-shared/*": ["../nook-web-shared/src/*"],
      "$app-wasm": ["../nook-web-shared/src/vault-app/lib/nook-wasm/nook_wasm"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../nook-web-shared/src/**/*.ts",
    "../nook-web-shared/src/**/*.svelte"
  ],
  "exclude": [
    "../nook-web-shared/src/vault-app/lib/nook-wasm*",
    "../nook-web-shared/src/vault-app/lib/extension-connect.ts",
    "../nook-web-shared/src/vault-app/lib/components/ExtensionConnectConsent.svelte"
  ]
}
